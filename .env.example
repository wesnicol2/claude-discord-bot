# ══════════════════════════════════════════════════════════════════════════════
# Claude Discord Bot – Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
# HOW TO USE:
#   cp .env.example .env
#   Fill in the values below, then run: docker-compose up -d
#
# SECURITY:
#   .env is git-ignored and must NEVER be committed.
#   Treat DISCORD_TOKEN like a password — rotate it immediately if leaked.
# ══════════════════════════════════════════════════════════════════════════════


# ── Discord secrets (REQUIRED) ────────────────────────────────────────────────

# Bot token from https://discord.com/developers/applications → Bot → Token
# Starts with your application ID followed by a dot.
DISCORD_TOKEN=


# ── Discord access control (REQUIRED) ────────────────────────────────────────
# These are non-secret IDs but must match your Discord server exactly.

# Numeric user ID of the ONLY person allowed to send commands to the bot.
# Right-click your username in Discord → "Copy User ID" (enable Developer Mode
# in Discord Settings → Advanced first).
DISCORD_ALLOWED_USERS=

# Numeric ID of the channel the bot watches for messages.
# Right-click the channel → "Copy Channel ID".
DISCORD_CHANNEL_ID=


# ── Authentication: Claude Pro OAuth vs. pay-per-use API key ─────────────────
#
# RECOMMENDED (Claude Pro/Max subscribers):
#   Leave ANTHROPIC_API_KEY blank. The bot uses the OAuth credentials in
#   claude-home/.credentials.json (copied from your host ~/.claude/).
#   Tokens refresh automatically — no manual renewal needed.
#
# ALTERNATIVE (pay-per-use):
#   Set ANTHROPIC_API_KEY to an API key from https://console.anthropic.com/
#   WARNING: setting this overrides OAuth and requires a funded API account.
ANTHROPIC_API_KEY=


# ── Tuning (optional — built-in defaults shown) ───────────────────────────────

# Seconds before Claude Code is killed and a timeout message is sent to Discord.
CLAUDE_TIMEOUT=600

# Seconds of silence before the bot sends a "still working…" heartbeat.
HEARTBEAT_INTERVAL=120
