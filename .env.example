# ─────────────────────────────────────────────────────────────────────────────
# Claude Discord Bot – Environment Variables Template
# Copy to .env and fill in values. NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Anthropic API key (set in Step 2)
ANTHROPIC_API_KEY=sk-ant-...

# Discord bot token (set in Step 2)
DISCORD_TOKEN=...

# Discord application/client ID (set in Step 2)
DISCORD_CLIENT_ID=...

# Comma-separated list of Discord guild IDs the bot is allowed in (set in Step 2)
DISCORD_ALLOWED_GUILDS=

# Comma-separated list of Discord user IDs allowed to interact with the bot
DISCORD_ALLOWED_USERS=

# Maximum tokens Claude Code can use per request
MAX_TOKENS=4096

# Timeout in seconds for a single Claude Code invocation
CLAUDE_TIMEOUT=120
