# ─────────────────────────────────────────────────────────────────────────────
# Secrets & credentials — NEVER committed
# ─────────────────────────────────────────────────────────────────────────────
.env
secrets/
*.key
*.pem

# ─────────────────────────────────────────────────────────────────────────────
# Runtime data — generated at runtime, not source
# ─────────────────────────────────────────────────────────────────────────────
logs/*
!logs/.gitkeep
workspace/*
!workspace/.gitkeep

# ─────────────────────────────────────────────────────────────────────────────
# Node.js
# ─────────────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.pnpm-store
.yarn/cache
.yarn/unplugged
dist/
build/
*.tsbuildinfo

# ─────────────────────────────────────────────────────────────────────────────
# OS & editor artifacts
# ─────────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# Docker build cache (not the .dockerignore file itself)

